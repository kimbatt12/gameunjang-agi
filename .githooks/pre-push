#!/usr/bin/env bash
set -u

abort() {
  printf 'pre-push: %s\n' "$1" >&2
  exit 1
}

repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || abort "failed to locate git repository root."
cd "$repo_root" || abort "failed to enter repository root: $repo_root"

# shellcheck source=.githooks/lib/pre-push-common.sh
. "$repo_root/.githooks/lib/pre-push-common.sh"
# shellcheck source=.githooks/lib/pre-push-validate.sh
. "$repo_root/.githooks/lib/pre-push-validate.sh"
# shellcheck source=.githooks/lib/pre-push-review.sh
. "$repo_root/.githooks/lib/pre-push-review.sh"

trap cleanup EXIT

remote_name=${1:-unknown}
remote_url=${2:-unknown}

read_push_updates
append_manual_update_if_needed

review_refs_file=$(mktemp "${TMPDIR:-/tmp}/pre-push-review-refs.XXXXXX") || abort "failed to create temporary review ref list."

while read -r local_ref local_sha remote_ref remote_sha; do
  plan_update "$local_ref" "$local_sha" "$remote_ref" "$remote_sha"
done <"$push_updates_file"

# Validation intentionally runs before read-only code review. The loop validates the
# exact commit object being pushed from a detached temporary worktree.
while read -r local_ref local_sha remote_ref remote_sha local_commit diff_base; do
  printf 'pre-push: validating %s (%s) against %s...\n' "$local_ref" "$local_commit" "$diff_base" >&2
  prepare_validation_worktree "$local_commit"
  run_validation "$validation_root" "$diff_base"
  remove_validation_worktree
done <"$review_refs_file"

run_code_review "$remote_name" "$remote_url"
